{
  "expo": {
    "name": "VolleyballAI",
    "slug": "VolleyballAI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "volleyballai",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jrrock26.VolleyballAI"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#E6F4FE"
      },
      "package": "com.jrrock26.VolleyballAI"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow VolleyballAI to access your camera to analyze your volleyball skills.",
          "microphonePermissionText": "Allow VolleyballAI to access your microphone to record audio during video analysis."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}